# Solarica backend — production .env for server deployment
# Place this file at /home/solarica/app/backend/.env on the server.
# The systemd unit (solarica.service) loads it via EnvironmentFile=.
#
# NOTE: The '#' in the DB password must be URL-encoded as '%23' inside DATABASE_URL.
#       Alternatively wrap the entire value in single quotes.
#
# Generate SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# ── Database ──────────────────────────────────────────────────────────────────
# DB name: solarica | DB user: solarica | schema: public
# '%23' is URL-encoding for '#' (the character in solarica1342#)
DATABASE_URL=postgresql://solarica:solarica1342%23@127.0.0.1:5432/solarica

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_RANDOM_64_HEX_CHARS

# ── CORS ──────────────────────────────────────────────────────────────────────
# After TLS: use https://
CORS_ORIGINS=https://solarica.wavelync.com,http://solarica.wavelync.com

# ── Import folder ─────────────────────────────────────────────────────────────
WATCH_IMPORT_FOLDER=false
