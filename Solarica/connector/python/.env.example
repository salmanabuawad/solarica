# Solarica Python Connector – environment variables
# Copy to .env and edit before running.

# Driver selection: mock | serial | vendor_export
PVPM_DRIVER=serial

# Cloud backend URL (where sync upload sends measurements)
BACKEND_BASE_URL=http://localhost:8000

# Local SQLite database (created automatically)
LOCAL_DB_PATH=./data/connector.db

# vendor_export driver: folder to watch for PVPM-exported files
WATCH_FOLDER=./import_watch

# Serial port settings (serial driver only)
SERIAL_BAUD_RATE=115200
SERIAL_TIMEOUT_SECONDS=3

# HTTP server
CONNECTOR_PORT=8765
LOG_LEVEL=INFO
