# Copy this file to deploy-credentials.local.ps1 (gitignored).
# deploy-solarica*.ps1 dot-sources it automatically.

# SSH target
$env:DEPLOY_HOST = "185.229.226.37"
$env:DEPLOY_USER = "root"                    # SSH user for initial setup; use solarica once created

# Paths on the server
$env:DEPLOY_PATH         = "/var/www/solarica"     # nginx root for React SPA
$env:BACKEND_REMOTE_PATH = "/home/solarica/app"    # backend venv + code live here
$env:DEPLOY_BACKEND_CHOWN = "solarica:solarica"

# systemd units to restart after backend deploy
$env:DEPLOY_SYSTEMD_RESTART = "solarica"

# App URL (shown in deploy output)
$env:DEPLOY_APP_URL = "https://solarica.wavelync.com/"

# Passwords (only needed for -InitializeDatabase / -SetupUser)
# $env:SOLARICA_DB_PASSWORD          = "solarica1342#"
# $env:SOLARICA_UNIX_PASSWORD        = "KortexDigital1342#"
# $env:POSTGRES_SUPERUSER_PASSWORD   = "postgres1342"    # postgres system role; default is postgres1342
