# ── Database ───────────────────────────────────────────────────
POSTGRES_USER=solarica
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=solarica

# ── Backend ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_generated_secret

ACCESS_TOKEN_EXPIRE_MINUTES=480

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example for production: https://solarica.yourdomain.com
CORS_ORIGINS=http://localhost

# ── Frontend port ──────────────────────────────────────────────
HTTP_PORT=80
