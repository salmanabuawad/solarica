    "general": {
      "title": "General Help",
      "tip1": {
        "title": "Navigation",
        "body": "Use the sidebar to switch between sections. Tabs at the top keep multiple views open at once."
      },
      "tip2": {
        "title": "Role-based access",
        "body": "Menu items and actions are shown based on your role. Contact your administrator if you need additional permissions."
      }
    },
    "dashboard": {
      "tip1": {
        "title": "Project summary",
        "body": "The dashboard shows live counts of active projects, pending tasks, approvals, and red flags sourced directly from the backend."
      },
      "tip2": {
        "title": "Quick actions",
        "body": "Use 'New Project' to launch the project wizard, or 'Upload Measurement' to import a PVPM file directly from this screen."
      }
    },
    "projects": {
      "tip1": {
        "title": "Project lifecycle",
        "body": "Every project moves through phases: Design → Validation → Implementation → Testing → Commissioning → Maintenance. Approval is required before advancing."
      }
    },
    "tasks": {
      "tip1": {
        "title": "Task workflow",
        "body": "Tasks can include messages, photo evidence, approvals, and test results. Technicians see only their assigned tasks."
      }
    },
    "inventory": {
      "tip1": {
        "title": "Material tracking",
        "body": "Materials are issued per project and tracked by quantity issued, returned, consumed, and missing. Red flags are raised automatically on discrepancies."
      }
    },
    "measurements": {
      "tip1": {
        "title": "Uploading measurements",
        "body": "Upload .SUI or validated .XLS files exported from your PVPM device. Records are automatically linked to the relevant project and tasks."
      }
    },
    "security": {
      "tip1": {
        "title": "IT/OT security monitoring",
        "body": "The security module tracks registered devices, open vulnerabilities (CVE/CVSS), and compliance scores across your operational network."
      }
    },
    "footer": {
      "hint": "Press Esc to close",
      "docs": "Full documentation"
    }
  },
